# =====================================================
# Supabase (required)
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =====================================================
# Google Gemini (required untuk AI features)
# Free tier: https://aistudio.google.com/apikey
# =====================================================
GEMINI_API_KEY=...
# Flash untuk summary & recommendation (quality):
GEMINI_MODEL_SUMMARY=gemini-2.5-flash
# Flash-Lite untuk evidence review & high-volume (rate limit lebih longgar):
GEMINI_MODEL_REVIEW=gemini-2.5-flash-lite

# =====================================================
# Email (Resend) — Phase 0+
# =====================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@milestone.atourin.com

# =====================================================
# WhatsApp (Fonnte) — Phase 2+
# =====================================================
FONNTE_API_TOKEN=
FONNTE_DEVICE=

# =====================================================
# Google (untuk GForm sync) — Phase 2+
# =====================================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# =====================================================
# App
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Atourin Milestone Tracker"
NEXT_PUBLIC_SUPPORT_EMAIL=support@atourin.com
